# musicguru.conf -- this application's own settings file.
# Copy to 'musicguru.conf' (same directory as the app). Loaded at startup
# and editable from the /config page. Only AR_DB_PASSWORD is strictly needed;
# the login is created on first run.

# audio_recognition — configuration for the newly added features.
# Everything here is OPTIONAL. Unset = the feature is off and the app behaves
# exactly as before (plus the DB-only features, which need no config). See
# audio_recognition/config.py for the full list of existing AR_* variables.

# --- Last.fm scrobbling --------------------------------------------------
# Needs AR_LASTFM_API_KEY (already used for enrichment) PLUS the two below.
# Get a session key once with:
#   AR_LASTFM_API_KEY=... AR_LASTFM_SECRET=... python -m audio_recognition.scrobble
AR_SCROBBLE=0
AR_LASTFM_SECRET=
AR_LASTFM_SESSION_KEY=
AR_SCROBBLE_MIN_SECONDS=30

# --- Now-playing publishing (Home Assistant, etc.) -----------------------
# A webhook that receives the current track as JSON on every change.
AR_NOWPLAYING_WEBHOOK=
# Optional MQTT (only used if paho-mqtt is installed and a host is set).
AR_MQTT_HOST=
AR_MQTT_PORT=1883
AR_MQTT_TOPIC=audio_recognition/now_playing
AR_MQTT_USER=
AR_MQTT_PASSWORD=

# --- Capture watchdog / alerts -------------------------------------------
# Alert if no audio is seen for this many minutes during active hours. 0 = off.
AR_WATCHDOG_SILENCE_MIN=0
AR_ACTIVE_HOURS=8-23
# Webhook receiving {"title","message"} as JSON, or an ntfy topic URL.
AR_NOTIFY_URL=
AR_NOTIFY_TIMEOUT=4

# --- Durability ----------------------------------------------------------
# Failed inserts are spooled here and replayed on the next successful write.
AR_DB_SPOOL_FILE=~/.local/state/audio_recognition_spool.jsonl

# --- Local recognition (fingerprint cache) -------------------------------
# Identify repeats without calling Shazam. Requires the fpcalc binary:
#   sudo apt install libchromaprint-tools
AR_LOCAL_RECOGNITION=1
AR_FP_MATCH_THRESHOLD=0.78
AR_FP_MAX_PER_TRACK=8
AR_FP_LENGTH_SEC=10

# --- Cover art in the database -------------------------------------------
# Store re-encoded covers in MySQL so art survives a lost disk cache and is
# never re-fetched from the internet.
AR_COVER_DB=1

# --- Web console login (optional) ----------------------------------------
# Set a password to require an interactive login. Hash is preferred; generate:
#   python -m audio_recognition.webapp.auth 'your password'
AR_WEB_USER=admin
# AR_WEB_PASSWORD_HASH='scrypt:...'      # preferred
# AR_WEB_PASSWORD=                        # plaintext alternative
# AR_WEB_SECRET_KEY=                      # rotates all sessions when changed
AR_WEB_SESSION_HOURS=720
# Machine/API access (Prometheus, health checks) can still use a token:
# AR_WEB_TOKEN=

# --- Core (required) -----------------------------------------------------
# The only strictly-required variable:
# AR_DB_PASSWORD=

# --- Plex matching (troubleshooting) -------------------------------------
# Set to 0 when AR_PLEX_BASE_URL is https://<ip>:32400 — Plex's *.plex.direct
# cert won't validate against a bare IP, and TLS verification will fail.
AR_PLEX_VERIFY_SSL=1
# Force a specific music library by name (otherwise the first one is used):
# AR_PLEX_MUSIC_SECTION=Music
# Parallel Plex lookups for the want-list (scales to huge libraries):
AR_PLEX_CONCURRENCY=12

# --- Spotify playlist export ---------------------------------------------
# Free app at https://developer.spotify.com/dashboard; add a redirect URI that
# points at this console, set these, then authorize once on the /config page.
# AR_SPOTIFY_CLIENT_ID=
# AR_SPOTIFY_CLIENT_SECRET=
# AR_SPOTIFY_REDIRECT_URI=http://<this-host>:8000/spotify/callback
AR_SPOTIFY_PLAYLIST_PUBLIC=0

# --- Tidal playlist export -----------------------------------------------
# No developer app; one-time device login. Enable, then authorize on the host:
#   python -m audio_recognition.services.tidal login

# --- Login & config editor -----------------------------------------------
# Login is MANDATORY: on first run the console sends you to a setup page to
# create a username + password (stored hashed here as AR_WEB_PASSWORD_HASH).
# You normally don't set these by hand. The /config page edits THIS file
# directly; secrets are write-only there.

# --- Local music library (use instead of Plex) ---------------------------
# Point at a folder of music files to power the want-list / M3U export without
# Plex. Scanned once (tags via mutagen). Plex wins if both are set.
# AR_LOCAL_LIBRARY_PATH=/srv/music

# --- Auto-playlist -------------------------------------------------------
# Append every newly heard track to a running playlist on each enabled service
# (deduped per service). Toggle these from the /config page too.
AR_AUTO_PLAYLIST_NAME=musicguru - heard
AR_AUTO_PLAYLIST_SPOTIFY=0
AR_AUTO_PLAYLIST_TIDAL=0
AR_AUTO_PLAYLIST_PLEX=0

# --- Capture ---------------------------------------------------------------
# Mic or line-in are both just ALSA devices. Find yours with `arecord -l` (or the
# 'List capture devices' button on /config), e.g. hw:1,0. Line-in is usually stereo.
# AR_ALSA_DEVICE=hw:1,0
# AR_CAPTURE_CHANNELS=1        # set 2 for a stereo line-in
